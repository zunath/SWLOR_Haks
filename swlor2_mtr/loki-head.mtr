# customshaderVS vslit_nm


customshadervs vslitc_sm_nm
customshaderfs fsFlowmap

renderhint NormalTangents
 
// Textures 
texture0 loki-head
texture1 null
texture2 null
texture3 null
texture4 null
texture5 loki-head_i
texture6 flow_south


##override the flow speed of the shader here
parameter float fSlideSpeed 0.15
transparency 1
parameter float fMixingTime 15.0